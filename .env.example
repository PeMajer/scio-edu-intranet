# Supabase
SUPABASE_URL=https://[projekt-id].supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Sanity
SANITY_PROJECT_ID=...
SANITY_DATASET=production
SANITY_API_TOKEN=sk...

# Google Calendar (service account — nevyžaduje veřejný kalendář)
# 1. Vytvoř service account v Google Cloud Console, stáhni JSON klíč
# 2. Sdílej kalendář s emailem service accountu
# 3. Vyplň hodnoty z JSON klíče
GOOGLE_SERVICE_ACCOUNT_EMAIL=calendar-reader@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_CALENDAR_ID=scioedu@scioskola.cz

# Obecné
PUBLIC_SITE_URL=http://localhost:3000
