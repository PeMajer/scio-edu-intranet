{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "czech",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(printf '%s' \"$INPUT\" | python3 -c \"import json,sys; print(json.loads(sys.stdin.read()).get('tool_input',{}).get('command',''))\" 2>/dev/null); if echo \"$CMD\" | grep -qE 'push\\s+--force(?!-with-lease)|push\\s+-f\\b'; then echo 'BLOCKED: git push --force is not allowed on this project.' >&2; exit 2; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx shadcn@latest *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git show *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./wrangler.toml)"
    ]
  }
}
